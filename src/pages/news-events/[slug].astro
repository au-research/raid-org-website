---
import { getCollection } from "astro:content";
import Layout from "@/layouts/main.astro";

export async function getStaticPaths() {
  const posts = await getCollection("news-events", ({ data }) => !data.draft);
  return posts.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { title, date, type, author, tags, heroImage } = entry.data;
const location = type === "event" ? entry.data.location : null;
const { Content } = await entry.render();

const formattedDate = date.toLocaleDateString("en-AU", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Layout title={`${title} | RAiD`}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-14">
    <a
      href="http://localhost:4321/news-events"
      class="text-sm text-raidTextPrimary hover:underline"
    >
      &larr; Back to News &amp; Events
    </a>

    {
      heroImage && (
        <img
          src={heroImage.src}
          alt={title}
          class="w-full h-56 object-cover rounded mt-8"
        />
      )
    }

    <div class="mt-8">
      <p class="text-xs text-raidTextPrimary font-semibold uppercase tracking-wide">
        {type === "event" ? "Event" : "News"}
        {
          location && (
            <>
              <span class="mx-2">·</span>
              {location}
            </>
          )
        }
      </p>
      <h1 class="text-raidTextPrimaryDark font-semibold text-2xl mt-2">
        {title}
      </h1>
      <p class="text-sm text-gray-500 mt-1">
        {formattedDate}
        {author && <span class="ml-2">· {author}</span>}
      </p>
      {
        tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-1 mt-3">
            {tags.map((tag) => (
              <span class="text-xs bg-raidGray text-raidTextPrimary px-2 py-0.5 rounded">
                {tag}
              </span>
            ))}
          </div>
        )
      }
    </div>

    <hr class="my-8 border-raidGray" />

    <div class="prose prose-a:text-raidTextPrimaryDark prose-a:underline max-w-none">
      <Content />
    </div>
  </div>
</Layout>
