---
import { getCollection } from "astro:content";
import Layout from "@/layouts/main.astro";

const allPosts = await getCollection(
  "news-events",
  ({ data }) => import.meta.env.DEV || !data.draft
);

const tagCounts = new Map<string, number>();
for (const post of allPosts) {
  for (const tag of post.data.tags ?? []) {
    tagCounts.set(tag, (tagCounts.get(tag) ?? 0) + 1);
  }
}

const tags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]);
---

<Layout title="All Tags | RAiD">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <a
      href="/news-events"
      class="text-sm text-raidTextPrimary hover:underline"
    >
      &larr; Back to News &amp; Events
    </a>

    <div class="mt-8 mb-12">
      <h1 class="text-raidTextPrimaryDark font-semibold text-3xl">All Tags</h1>
      <p class="text-sm text-gray-500 mt-1">{tags.length} {tags.length === 1 ? "tag" : "tags"}</p>
    </div>

    {tags.length > 0 ? (
      <div class="flex flex-wrap gap-3">
        {tags.map(([tag, count]) => (
          <a
            href={`/news-events/tag/${tag}`}
            class="flex items-center gap-2 bg-raidGray hover:bg-raidPrimary text-raidTextPrimary hover:text-white px-4 py-2 rounded text-sm font-semibold transition-colors"
          >
            {tag}
            <span class="bg-white text-raidTextPrimary text-xs font-bold px-1.5 py-0.5 rounded-full">
              {count}
            </span>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-gray-500 text-sm">No tags found.</p>
    )}
  </div>
</Layout>
