---
import { getCollection } from "astro:content";

const allPosts = await getCollection(
  "news-events",
  ({ data }) => !data.draft && data.type === "news"
);

const newsPosts = allPosts.sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
---

{
  newsPosts.length > 0 && (
    <div class="bg-raidGray">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
        <h2 class="text-raidPrimary font-semibold text-2xl mb-8">
          Latest News
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {newsPosts.map((post) => (
            <div class="bg-white rounded shadow flex flex-col overflow-hidden">
              {post.data.heroImage && (
                <img
                  src={post.data.heroImage.src}
                  alt={post.data.title}
                  class="w-full h-40 object-cover"
                />
              )}
              <div class="p-6 flex flex-col gap-3 flex-grow">
                <p class="text-xs text-raidTextPrimary font-semibold uppercase tracking-wide">
                  {post.data.date.toLocaleDateString("en-AU", {
                    year: "numeric",
                    month: "long",
                  })}
                  {post.data.author && (
                    <span class="ml-2 text-gray-400">· {post.data.author}</span>
                  )}
                </p>
                <h3 class="text-base font-semibold text-raidTextPrimaryDark leading-snug">
                  {post.data.title}
                </h3>
                <p class="text-sm text-gray-600 flex-grow">{post.data.summary}</p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1">
                    {post.data.tags.map((tag) => (
                      <span class="text-xs bg-raidGray text-raidTextPrimary px-2 py-0.5 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <a
                  href={`http://localhost:4321/news-events/${post.slug}`}
                  class="text-sm text-raidTextPrimaryDark hover:underline font-semibold mt-auto"
                >
                  Read more &rarr;
                </a>
              </div>
            </div>
          ))}
        </div>
      </div>
    </div>
  )
}
