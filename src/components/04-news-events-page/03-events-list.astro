---
import { getCollection, type CollectionEntry } from "astro:content";

type EventPost = CollectionEntry<"news-events"> & {
  data: Extract<CollectionEntry<"news-events">["data"], { type: "event" }>;
};

const allEvents = (await getCollection(
  "news-events",
  ({ data }) => !data.draft && data.type === "event"
)) as EventPost[];

const today = new Date();
today.setHours(0, 0, 0, 0);

const sorted = allEvents.sort(
  (a, b) => a.data.date.getTime() - b.data.date.getTime()
);

const upcoming = sorted.filter((p) => p.data.date >= today);
const past = sorted.filter((p) => p.data.date < today).reverse();
---

{
  allEvents.length > 0 && (
    <div class="bg-white">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
        {upcoming.length > 0 && (
          <>
            <h2 class="text-raidPrimary font-semibold text-2xl mb-8">
              Upcoming Events
            </h2>
            <div class="flex flex-col gap-8 mb-16">
              {upcoming.map((post) => (
                <div class="border-l-4 border-raidPrimary pl-6 py-2">
                  <p class="text-sm text-raidTextPrimary font-semibold">
                    {post.data.date.toLocaleDateString("en-AU", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                    <span class="mx-2 text-raidSecondary">·</span>
                    {post.data.location}
                  </p>
                  <h3 class="text-lg font-semibold text-raidTextPrimaryDark mt-1">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-gray-600 mt-2 max-w-2xl">
                    {post.data.summary}
                  </p>
                  {post.data.tags && post.data.tags.length > 0 && (
                    <div class="flex flex-wrap gap-1 mt-2">
                      {post.data.tags.map((tag) => (
                        <span class="text-xs bg-raidGray text-raidTextPrimary px-2 py-0.5 rounded">
                          {tag}
                        </span>
                      ))}
                    </div>
                  )}
                  <a
                    href={`http://localhost:4321/news-events/${post.slug}`}
                    class="inline-block mt-3 text-sm text-raidTextPrimaryDark hover:underline font-semibold"
                  >
                    Learn more &rarr;
                  </a>
                </div>
              ))}
            </div>
          </>
        )}

        {past.length > 0 && (
          <>
            <h2 class="text-raidPrimary font-semibold text-2xl mb-8">
              Past Events
            </h2>
            <div class="flex flex-col gap-8">
              {past.map((post) => (
                <div class="border-l-4 border-raidGray pl-6 py-2">
                  <p class="text-sm text-raidTextPrimary font-semibold">
                    {post.data.date.toLocaleDateString("en-AU", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                    <span class="mx-2 text-raidSecondary">·</span>
                    {post.data.location}
                  </p>
                  <h3 class="text-lg font-semibold text-raidTextPrimaryDark mt-1">
                    {post.data.title}
                  </h3>
                  <p class="text-sm text-gray-600 mt-2 max-w-2xl">
                    {post.data.summary}
                  </p>
                  <a
                    href={`http://localhost:4321/news-events/${post.slug}`}
                    class="inline-block mt-3 text-sm text-raidTextPrimaryDark hover:underline font-semibold"
                  >
                    View details &rarr;
                  </a>
                </div>
              ))}
            </div>
          </>
        )}
      </div>
    </div>
  )
}
